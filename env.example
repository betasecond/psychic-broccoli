# ============================================================
# CourseArk Production Environment Variables
# Copy this file to .env and update values before deployment
# ============================================================

# ============================================================
# REQUIRED - These must be set before starting
# ============================================================

# GitHub Container Registry owner (your GitHub username)
# Used to pull images: ghcr.io/<GHCR_OWNER>/psychic-broccoli-*
GHCR_OWNER=your-github-username

# JWT signing secret - USE A STRONG RANDOM STRING IN PRODUCTION
# Generate one with: openssl rand -base64 32
JWT_SECRET=change-me-in-production-use-strong-random-string

# ============================================================
# OPTIONAL - These have sensible defaults
# ============================================================

# Web server port (external)
WEB_PORT=80

# Enable test data seeding (false for production, true for demo/development)
# Default: false (disabled in production for security)
ENABLE_SEED=false

# Path to Docker config.json for GHCR authentication (Watchtower uses this)
# Default: /root/.docker/config.json (works for root user)
# For non-root user, set to: /home/<username>/.docker/config.json
# DOCKER_CONFIG_PATH=/root/.docker/config.json

# RAG / AI configuration
# Default OpenRouter/OpenAI-compatible configuration
RAG_PROVIDER=openrouter
OPENAI_API_KEY=your-openai-or-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash
EMBEDDING_MODEL=openai/text-embedding-3-small

# Alibaba Cloud Model Studio / DashScope OpenAI-compatible configuration
# Set RAG_PROVIDER=dashscope and DASHSCOPE_API_KEY to use these defaults:
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_BATCH_SIZE=10
DASHSCOPE_API_KEY=
EMBEDDING_BATCH_SIZE=
